auto-update-channel = tip
background-opacity = 1
background-opacity-cells=true

desktop-notifications = true

shell-integration = zsh
shell-integration-features = true
shell-integration-features = no-cursor
cursor-style=block
command = /bin/zsh

input = "tmux new-session -A -s main\n"
cursor-style=block
cursor-style-blink=false
font-size = 27
font-synthetic-style = true
font-thicken = true
font-thicken-strength = 50
window-inherit-working-directory = true
font-family = "Iosevka"

macos-window-shadow = true 
window-padding-x = 12
# window-padding-y = 8
# window-padding-x = 8
# window-padding-y = 8
# window-padding-y = 24
# window-padding-x = 8
# window-padding-y = 6, 6
# window-padding-balance = true

copy-on-select = true
confirm-close-surface = false

keybind=ctrl+a=unbind
keybind=ctrl+b=unbind
keybind=ctrl+e=unbind
keybind=ctrl+f=unbind
keybind=ctrl+g=unbind
keybind=ctrl+h=unbind
keybind=ctrl+j=unbind
keybind=ctrl+k=unbind
keybind=ctrl+l=unbind
keybind=ctrl+n=unbind
keybind=ctrl+o=unbind
keybind=ctrl+p=unbind
keybind=ctrl+r=unbind
keybind=ctrl+s=unbind
keybind=ctrl+t=unbind
keybind=ctrl+u=unbind
keybind=ctrl+v=unbind
keybind=ctrl+w=unbind
keybind=ctrl+x=unbind
keybind=ctrl+y=unbind
keybind=ctrl+z=unbind
keybind=ctrl+space=unbind
 
# theme = Gruber Darker 
theme = gruvbox
